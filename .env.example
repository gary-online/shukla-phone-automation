# Twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Anthropic (or OpenRouter)
ANTHROPIC_API_KEY=your_anthropic_api_key
# ANTHROPIC_BASE_URL=https://openrouter.ai/api  # Uncomment to use OpenRouter
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Google Chat Webhook
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/SPACE_ID/messages?key=KEY&token=TOKEN

# Gmail API (OAuth2)
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token
GMAIL_FROM_ADDRESS=pps@shuklamedical.com
GMAIL_TO_ADDRESS=pps-team@shuklamedical.com

# Server
PORT=8080
HOST=0.0.0.0
BASE_URL=https://your-server-url.com

# CSV
CSV_OUTPUT_DIR=./data
